# Database
DATABASE_URL=sqlite+aiosqlite:///./chat_agent.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chat_agent

# Auth (OAuth2 / JWT)
OAUTH2_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXX/.well-known/jwks.json
OAUTH2_AUDIENCE=your-app-client-id

# LLM Providers
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Optional: custom OpenAI-compatible endpoint
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_API_KEY=none
CUSTOM_LLM_MODEL=llama3

# Rate Limiting
RATE_LIMIT_RPM=60

# Context Window
MAX_HISTORY_MESSAGES=50

# System Prompt
DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant.

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# App
APP_VERSION=0.1.0
LOG_LEVEL=INFO
